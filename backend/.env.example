# Path to saved Avito cookies
AVITO_COOKIES_PATH=./cookies/avito-cookies.json

# Set to "false" for first run to log in manually
PUPPETEER_HEADLESS=false

# Chat name to monitor
TARGET_CHAT_NAME=Рушан

# Polling interval in milliseconds
POLL_INTERVAL=5000

# Chrome profile directory (persists session between restarts)
USER_DATA_DIR=./chrome-profile
